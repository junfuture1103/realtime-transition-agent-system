{
  "schema_id": "kaggle_fraud_transactions_v1",
  "display_name": "Kaggle fraud transactions schema",
  "description": "Default training schema based on Kaggle fraud transaction datasets with timestamp, cardholder, merchant, location, amount, and is_fraud target columns.",
  "source": {
    "name": "Kaggle fraud transactions dataset",
    "url": "https://www.kaggle.com/datasets/dermisfit/fraud-transactions-dataset",
    "notes": "Selected because the columns are interpretable for security education: time, amount, merchant category, cardholder profile, geo distance, and binary fraud labels."
  },
  "target": "is_fraud",
  "allow_unknown_features": false,
  "display": {
    "amount_field": "amt",
    "account_field": "cc_num",
    "category_field": "category",
    "channel_field": "merchant",
    "country_field": "state"
  },
  "decision": {
    "review_threshold": 0.55,
    "block_threshold": 0.8
  },
  "retrain": {
    "min_samples": 80,
    "supervised_min_labeled": 60,
    "max_recent_samples": 8000,
    "retrain_every": 16,
    "allow_high_confidence_pseudo_labels": true,
    "pseudo_label_min_confidence": 0.95,
    "isolation_contamination": 0.04
  },
  "derived_features": [
    {
      "name": "customer_merchant_distance_km",
      "type": "geo_distance",
      "lat": "lat",
      "long": "long",
      "other_lat": "merch_lat",
      "other_long": "merch_long"
    },
    {
      "name": "balance_delta",
      "type": "difference",
      "left": "old_balance",
      "right": "new_balance"
    }
  ],
  "fields": [
    {
      "name": "trans_date_trans_time",
      "type": "datetime",
      "role": "feature",
      "required": true,
      "default": "2020-06-21 12:14:25",
      "derive": [
        "hour",
        "day_of_week",
        "month",
        "is_weekend"
      ],
      "include_raw": false,
      "description": "Transaction timestamp."
    },
    {
      "name": "cc_num",
      "type": "text",
      "role": "entity",
      "train": false,
      "required": true,
      "default": "4767265376804500",
      "description": "Anonymized credit card/account identifier."
    },
    {
